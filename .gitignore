# Ambiente Virtual do Python (Virtual Environment)
tcc_env/
env/

# Cache do Python (arquivos compilados bytecode)
__pycache__/
*.pyc
*.pyo
*.pyd

# Configurações locais do VS Code
.vscode/

# Arquivos temporários e do sistema operacional
.DS_Store
Thumbs.db
desktop.ini
*.log

# Pastas de análises e bases de exemplo
analises/
TCC - Base e Exemplos/

